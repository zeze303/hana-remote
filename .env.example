# ============================================
# Render 中继服务
# ============================================
PORT=3000
JWT_SECRET=your_jwt_secret_here
SESSION_TIMEOUT=1800000
RATE_LIMIT_LOGIN=5
RATE_LIMIT_WINDOW=900000

# ============================================
# Worker 认证（插件连接时验证）
# ============================================
WORKER_SECRET=your_worker_secret_here

# ============================================
# Hanako 插件
# ============================================
RELAY_URL=wss://your-domain.com/ws
